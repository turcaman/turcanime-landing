<section class="px-5 py-24 bg-surface-elevated">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-12 text-center text-white">¿Por qué cambiarte a Turcanime?</h2>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="p-8 rounded-2xl bg-surface border border-border">
        <h3 class="text-xl font-bold mb-6 text-text-secondary">Webs tradicionales ❌</h3>
        <ul class="space-y-4 text-text-secondary">
          <li class="flex items-start gap-3">
            <span class="text-red-500">✕</span> Publicidad intrusiva y molesta
          </li>
          <li class="flex items-start gap-3">
            <span class="text-red-500">✕</span> Navegación caótica y difícil
          </li>
          <li class="flex items-start gap-3">
            <span class="text-red-500">✕</span> Historial que se pierde al cerrar el navegador
          </li>
          <li class="flex items-start gap-3">
            <span class="text-red-500">✕</span> Datos personales expuestos
          </li>
        </ul>
      </div>
      <div class="p-8 rounded-2xl bg-primary/10 border border-primary/20">
        <h3 class="text-xl font-bold mb-6 text-white">Turcanime ✅</h3>
        <ul class="space-y-4 text-white">
          <li class="flex items-start gap-3">
            <span class="text-primary">✓</span> 100% libre de anuncios
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary">✓</span> Interfaz diseñada para fans
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary">✓</span> Progreso guardado localmente
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary">✓</span> Máxima privacidad garantizada
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
