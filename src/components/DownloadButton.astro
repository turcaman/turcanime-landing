---
import { Download } from '@lucide/astro';

interface Props {
  href: string;
  label: string;
  download?: boolean;
}

const { href, label, download = false } = Astro.props;
---

<a
  href={href}
  class="btn-primary inline-flex items-center justify-center gap-2 min-w-[140px]"
  download={download}
>
  <Download size={16} />
  {label}
</a>
