---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="canonical" href={Astro.url} />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="preload" href="/screenshots/portrait.avif" as="image" />
		
		<meta name="description" content="Turcanime: aplicación de streaming de anime en español latino para Android. Privada, sin anuncios. Disfruta de tus series favoritas con fluidez." />
		<meta name="keywords" content="Turcanime, anime, anime latino, streaming, android, apk, español, subtitulado, castellano, sin anuncios, privado" />
		<meta name="robots" content="index, follow" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Turcanime: la experiencia definitiva para ver anime en español latino en Android." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:site_name" content="Turcanime" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content="Turcanime: la experiencia definitiva para ver anime en español latino en Android." />
	</head>
	<body class="bg-black text-white font-sans antialiased">
		<slot />
	</body>
</html>
